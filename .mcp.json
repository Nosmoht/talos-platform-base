{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "${PWD}/scripts/mcp-github-wrapper.sh",
      "args": []
    },
    "kubernetes-mcp-server": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/kubernetes-mcp-server",
      "args": ["--read-only", "--disable-multi-cluster"]
    },
    "talos": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/talos-mcp",
      "args": [],
      "env": {
        "TALOS_CONTEXT": "homelab"
      }
    }
  }
}
