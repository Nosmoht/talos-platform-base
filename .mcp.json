{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "gh",
      "args": ["mcp-server"],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "kubernetes": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "kubectl-mcp-server"]
    },
    "talos": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "talos-mcp"],
      "env": {
        "TALOS_CONTEXT": "homelab"
      }
    }
  }
}
