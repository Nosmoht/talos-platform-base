talos/talosconfig
talos/generated/
talos/.secrets.dec.yaml
talos/.versions.stamp
/cluster.yaml
/talos/_out/
/kubernetes/bootstrap/argocd/_out/
# Claude Code harness runtime dir — agent scratch state; this base ships
# no .claude/ tree by policy (see CLAUDE.md).
.claude/
# Harness scratchpad (validation cache, conftest output, plan workspaces).
.work/
# Transitional: keep ignored until all developer workstations have run `make migrate-cluster-yaml`.
.claude/environment.yaml
Plans/

# MCP config local overrides and pre-apply snapshots
.mcp.json.local
.mcp.json.bak-*

# Kustomize-extracted Helm charts (rendered at build time, not stored in repo)
kubernetes/base/infrastructure/*/charts/

# Rendered Manifests Pipeline (Phase B):
# .render-stage1/ holds Stage-1 (helm template) output; intermediate, never committed.
# .helm-cache/ holds pulled chart tarballs; deterministic by chart.lock.yaml.tgz_sha256.
# _rendered/ IS committed (Stage-2 output, OCI-payload).
kubernetes/base/infrastructure/*/.render-stage1/
.helm-cache/

# Auto Claude data directory
.auto-claude/

# Auto Claude generated files
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.worktrees/
.security-key
logs/security/
